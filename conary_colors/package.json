{
    "name": "conary-colors",
    "displayName": "Conary Colors",
    "description": "Custom syntax highlighting and colors for the Conary programming language",
    "version": "0.0.1",
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "languages": [{
            "id": "conary",
            "aliases": ["Conary", "conary"],
            "extensions": [".cnry"]
        }],
        "grammars": [{
            "language": "conary",
            "scopeName": "source.cnry",
            "path": "./conary.tmLanguage.json"
        }]
    }
}